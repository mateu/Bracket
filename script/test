#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

# Ensure project-local Perl modules are visible (local::lib style)
export PERL5LIB="$ROOT_DIR/local/lib/perl5${PERL5LIB:+:$PERL5LIB}"

# Run full test suite by default, or pass through args/files
if [[ $# -eq 0 ]]; then
  exec prove -lr t
else
  exec prove -lr "$@"
fi
