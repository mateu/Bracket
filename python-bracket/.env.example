# Application
APP_NAME=Python Bracket API
DEBUG=false
VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./bracket.db
# DATABASE_URL=postgresql://user:password@localhost:5432/bracket

# Security
SECRET_KEY=your-secret-key-change-in-production-make-it-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=["*"]
ALLOWED_METHODS=["*"]
ALLOWED_HEADERS=["*"]

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

